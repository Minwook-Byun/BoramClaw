# BoramClaw Environment Variables Template
# Copy this file to .env and fill in your values

# ===========================================
# LLM Settings
# ===========================================

# LLM Provider: 'claude' or 'codex'
LLM_PROVIDER=claude

# Claude API (for 'claude' or 'hybrid' mode)
ANTHROPIC_API_KEY=sk-ant-xxxxx
CLAUDE_MODEL=claude-sonnet-4-5-20250929
CLAUDE_MAX_TOKENS=1024

# Codex CLI (for 'codex' mode or advanced workflows)
CODEX_COMMAND=codex
CODEX_MODEL=

# ===========================================
# Tool Execution Settings
# ===========================================
CUSTOM_TOOL_DIR=tools
TOOL_WORKDIR=.
TOOL_TIMEOUT_SECONDS=300
STRICT_WORKDIR_ONLY=1

# ===========================================
# Scheduler Settings
# ===========================================
SCHEDULER_ENABLED=1
SCHEDULER_POLL_SECONDS=300
SCHEDULE_FILE=schedules/jobs.json
SCHEDULER_TIMEZONE=Asia/Seoul

# ===========================================
# Logging Settings
# ===========================================
CHAT_LOG_FILE=logs/chat_log.jsonl
SESSION_TIMESERIES_FILE=logs/session_timeseries.jsonl
LOG_BASE_DIR=logs
SESSION_LOG_SPLIT=0

# ===========================================
# AutoDashboard Timeseries Sync
# ===========================================
AUTO_DASHBOARD_TIMESERIES_ENDPOINT=http://127.0.0.1:3000/api/dashboard/timeseries/append
AUTO_DASHBOARD_TIMESERIES_FILE=
AUTO_DASHBOARD_TIMESERIES_FALLBACK_FILE=logs/autodashboard_timeseries_sync_fallback.jsonl
AUTO_DASHBOARD_TIMESERIES_KINDS=wrapup,codex_rollout
AUTO_DASHBOARD_TIMESERIES_DAYS_BACK=14
AUTO_DASHBOARD_TIMESERIES_MAX_ROWS=200
AUTO_DASHBOARD_TIMESERIES_TIMEOUT_SECONDS=20
AUTO_DASHBOARD_TIMESERIES_NOT_BEFORE=
AUTO_DASHBOARD_RETROSPECTIVE_POSTS_FILE=
BORAMCLAW_WRAPUP_HISTORY_FILE=
BORAMCLAW_CODEX_SESSIONS_ROOT=
BORAMCLAW_WRAPUP_DAILY_FOCUS=OpenClaw식 일일 회고와 다음 세션 첫 TODO 정리
BORAMCLAW_WRAPUP_CODEX_TIMEOUT_SECONDS=180
BORAMCLAW_RETROSPECTIVE_OUTPUT_DIR=logs/reviews/daily
BORAMCLAW_RETROSPECTIVE_REPO_ROOTS=

# ===========================================
# Health Server (for Watchdog)
# ===========================================
HEALTH_SERVER_ENABLED=1
HEALTH_PORT=8080

# ===========================================
# Agent Mode
# ===========================================
AGENT_MODE=interactive  # or 'daemon'

# ===========================================
# screenpipe Integration (Optional)
# ===========================================
SCREENPIPE_API_URL=http://localhost:3030

# ===========================================
# Web UI (Optional)
# ===========================================
WEB_UI_ENABLED=0
WEB_UI_PORT=8091

# ===========================================
# Telegram Integration (Optional)
# ===========================================
TELEGRAM_ENABLED=0
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALLOWED_CHAT_ID=your_chat_id_here

# ===========================================
# Security Settings
# ===========================================
ENCRYPT_LOGS=0
ENCRYPTION_KEY_ID=default

# ===========================================
# Experimental Features
# ===========================================
FORCE_TOOL_USE=0
DRY_RUN=0
CHECK_DEPENDENCIES_ON_START=0

# ===========================================
# Advanced Workflows (Codex-backed)
# ===========================================
ADVANCED_FEATURES_ENABLED=1
ADVANCED_PROVIDER=codex
